# Copy this file to .env and customize as needed.
# All values are optional — code defaults are used if unset.
# .env is gitignored and never committed.

# Server port
PORT=5051

# Vite dev server port
VITE_PORT=5173

# SQLite database directory (default: ~/.api-dashboard)
# API_DASHBOARD_DIR=~/.api-dashboard

# Digest LLM config (alternative to digest.cfg)
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Walkthrough voice studio (local-only branch) -----------------------------

# OPTION 1: Gemini TTS (preview) —— 一步上路,起步推荐
# Get from https://aistudio.google.com/apikey (AI Studio key, AIzaSy...)
# 用 gemini-2.5-flash-preview-tts 模型,免费层额度够 demo;PREVIEW 模型 SLA 不保证
# GEMINI_API_KEY=

# OPTION 2: Google Cloud Text-to-Speech (Wavenet / Neural2 / Chirp HD) —— 质量上一档
# Get from https://console.cloud.google.com/apis/credentials
#   1. 选 / 建 GCP 项目;2. 启用 Cloud Text-to-Speech API;3. 建 API key 限制到该 API
# Free tier: 1M chars/月 Standard + 1M chars/月 WaveNet/Neural2 + 100k Chirp HD
# GOOGLE_TTS_API_KEY=

# OPTION 3: MiniMax T2A v2 (海螺) —— 中文表现力 SOTA,教学口吻自然,推荐主轨
#   国内平台:https://platform.minimaxi.com (注册→实名→「账户管理」拿 API Key + GroupId)
#   控制台「语音合成 / 音色」可试听挑 voice_id;计费按字符,一集中文很便宜
#   两个平台 key/GroupId 不通用:国内 host=api.minimax.chat,国际 host=api.minimaxi.chat
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
# MINIMAX_API_HOST=api.minimax.chat        # 国际平台改 api.minimaxi.chat
# MINIMAX_MODEL=speech-02-hd               # 可选;也可 speech-02-turbo / 更新款
# MINIMAX_VOICE=female-chengshu            # 可选;控制台里挑你喜欢的 voice_id
# MINIMAX_SPEED=1.0                        # 可选;教学略慢可设 0.92~0.96
# MINIMAX_EMOTION=                         # 可选;happy / neutral …
