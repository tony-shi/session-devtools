# Copy this file to .env and customize as needed.
# All values are optional — code defaults are used if unset.
# .env is gitignored and never committed.

# Server port
PORT=5051

# Vite dev server port
VITE_PORT=5173

# SQLite database directory (default: ~/.api-dashboard)
# API_DASHBOARD_DIR=~/.api-dashboard

# Digest LLM config (alternative to digest.cfg)
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
