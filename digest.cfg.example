[llm]
# API base URL (Anthropic-compatible endpoint)
# Priority: ANTHROPIC_BASE_URL env var > this setting > default (https://api.anthropic.com)
# Uncomment and set to use a custom endpoint (e.g. a proxy or compatible provider):
# base_url = https://api.anthropic.com

# Bearer token for Authorization header
# Priority: ANTHROPIC_API_KEY env var > this setting
token = your-api-key-here

# Model to use for daily digest generation
model = claude-haiku-4-5-20251001

# Maximum output tokens for each digest
max_tokens = 4096

# Set to true to enable real LLM calls (requires a valid token)
enabled = false
