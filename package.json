{
  "name": "session-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "client:dev": "cd client && bun run dev",
    "build": "cd client && bun run build",
    "start": "bun server/index.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "concurrently": "^9.1.2"
  }
}
