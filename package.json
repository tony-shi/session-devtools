{
  "name": "session-devtools",
  "version": "0.1.0-alpha",
  "description": "Local devtools for AI coding sessions. Claude Code first.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tony-shi/session-dashboard"
  },
  "workspaces": ["packages/*", "client"],
  "scripts": {
    "dev": "bash scripts/setup-env.sh && concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "server/node_modules/.bin/tsx --tsconfig server/tsconfig.node.json --watch server/main.ts",
    "client:dev": "cd client && bun run dev",
    "build": "cd client && bun run build",
    "start": "bash scripts/setup-env.sh && server/node_modules/.bin/tsx --tsconfig server/tsconfig.node.json server/main.ts",
    "test": "cd server && npm test",
    "env:init": "[ -f .env ] || cp .env.example .env && echo 'Created .env from .env.example'",
    "proxy-v2:build": "mkdir -p \"$HOME/.api-dashboard/proxy-v2-runtime\" && node_modules/.bin/esbuild server/src/proxy-v2/server/start.ts --bundle --platform=node --outfile=\"$HOME/.api-dashboard/proxy-v2-runtime/start.mjs\" --format=esm",
    "proxy:start": "npm run proxy-v2:build && node \"$HOME/.api-dashboard/proxy-v2-runtime/start.mjs\"",
    "context:audit": "server/node_modules/.bin/tsx scripts/context-audit.ts",
    "context:audit:since-last": "server/node_modules/.bin/tsx scripts/context-audit.ts --since-last",
    "context:audit:fixtures": "server/node_modules/.bin/tsx scripts/context-audit.ts --fixtures",
    "context:audit:mark-baseline": "server/node_modules/.bin/tsx scripts/context-audit.ts mark-baseline",
    "context:audit:clear": "server/node_modules/.bin/tsx scripts/context-audit.ts clear",
    "context:audit:clear:keep": "server/node_modules/.bin/tsx scripts/context-audit.ts clear --keep",
    "context:audit:fixtures:rule-coverage": "server/node_modules/.bin/tsx scripts/context-audit-rule-coverage.ts",
    "context:audit:fixtures:full": "server/node_modules/.bin/tsx scripts/context-audit-fixtures-full.ts",
    "reconstruct:list": "server/node_modules/.bin/tsx scripts/reconstruct-parallel.ts list",
    "reconstruct:command": "server/node_modules/.bin/tsx scripts/reconstruct-parallel.ts command",
    "reconstruct:commands": "server/node_modules/.bin/tsx scripts/reconstruct-parallel.ts commands"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-forge": "^1.3.11",
    "concurrently": "^9.1.2"
  }
}
