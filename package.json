{
  "name": "session-devtools",
  "version": "0.1.0-alpha",
  "description": "Local devtools for AI coding sessions. Claude Code first.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tony-shi/session-dashboard"
  },
  "workspaces": ["packages/*", "client"],
  "scripts": {
    "dev": "bash scripts/setup-env.sh && bun install --frozen-lockfile && concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "start:node": "server/node_modules/.bin/tsx --tsconfig server/tsconfig.node.json server/main.ts",
    "dev:node": "server/node_modules/.bin/tsx --tsconfig server/tsconfig.node.json --watch server/main.ts",
    "client:dev": "cd client && bun install --frozen-lockfile && bun run dev",
    "build": "cd client && bun run build",
    "start": "bash scripts/setup-env.sh && bun server/index.ts",
    "env:init": "[ -f .env ] || cp .env.example .env && echo 'Created .env from .env.example'",
    "proxy-v2:build": "mkdir -p \"$HOME/.api-dashboard/proxy-v2-runtime\" && bun build server/src/proxy-v2/server/start.ts --target=node --outfile=\"$HOME/.api-dashboard/proxy-v2-runtime/start.mjs\"",
    "proxy:start": "bun run proxy-v2:build && node \"$HOME/.api-dashboard/proxy-v2-runtime/start.mjs\"",
    "context:audit": "bun run scripts/context-audit.ts",
    "context:audit:since-last": "bun run scripts/context-audit.ts --since-last",
    "context:audit:fixtures": "bun run scripts/context-audit.ts --fixtures",
    "context:audit:mark-baseline": "bun run scripts/context-audit.ts mark-baseline",
    "context:audit:clear": "bun run scripts/context-audit.ts clear",
    "context:audit:clear:keep": "bun run scripts/context-audit.ts clear --keep",
    "context:audit:fixtures:rule-coverage": "bun run scripts/context-audit-rule-coverage.ts",
    "context:audit:fixtures:full": "bun run scripts/context-audit-fixtures-full.ts",
    "reconstruct:list": "bun run scripts/reconstruct-parallel.ts list",
    "reconstruct:command": "bun run scripts/reconstruct-parallel.ts command",
    "reconstruct:commands": "bun run scripts/reconstruct-parallel.ts commands"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.13",
    "@types/node-forge": "^1.3.11",
    "bun-types": "^1.3.12",
    "concurrently": "^9.1.2"
  }
}
