{
  "name": "session-devtools",
  "version": "0.1.0-alpha.7",
  "description": "Local devtools for AI coding sessions. Claude Code first.",
  "license": "MIT",
  "author": "tony-shi <realshihuashen@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tony-shi/session-devtools.git"
  },
  "homepage": "https://github.com/tony-shi/session-devtools#readme",
  "bugs": {
    "url": "https://github.com/tony-shi/session-devtools/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "claude-code",
    "ai",
    "devtools",
    "sessions",
    "dashboard"
  ],
  "type": "module",
  "bin": {
    "session-devtools": "bin/session-devtools.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx --tsconfig server/tsconfig.node.json server/main.ts",
    "client:dev": "npm run dev --workspace=client",
    "build": "npm run build:server && npm run build:client",
    "build:client": "cd client && npm run build && rm -rf ../dist/public && cp -r ../server/public ../dist/public",
    "build:server": "npm run corpus:sync && tsup",
    "corpus:sync": "npx tsx server/scripts/corpus-sync.ts",
    "corpus:check": "npx tsx server/scripts/corpus-sync.ts --check",
    "coverage": "npx tsx server/scripts/coverage-report.ts",
    "drift": "npx tsx server/scripts/check-piebald-drift.ts",
    "voice": "npx tsx scripts/voice/synth.ts",
    "voice:agent-loop:zh": "npx tsx scripts/voice/synth.ts agent-loop --lang zh --provider mock",
    "voice:agent-loop:en": "npx tsx scripts/voice/synth.ts agent-loop --lang en --provider mock",
    "voice:watch": "npx tsx scripts/voice/watch.ts",
    "voice:watch:agent-loop": "npx tsx scripts/voice/watch.ts agent-loop --langs zh,en --provider mock",
    "prepack": "npm run build",
    "prepublishOnly": "node -e \"if (process.env.PUBLISH_FROM_SCRIPT !== '1') { console.error('ERROR: Use scripts/publish.sh instead of npm publish directly.'); process.exit(1); }\"",
    "start": "node bin/session-devtools.js",
    "test": "cd server && npm test",
    "env:init": "[ -f .env ] || cp .env.example .env && echo 'Created .env from .env.example'"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "better-sqlite3": "^12.9.0",
    "fastify": "^4.29.0",
    "node-forge": "^1.3.1",
    "open": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/node-forge": "^1.3.11",
    "concurrently": "^9.1.2",
    "esbuild-plugin-swc": "^1.0.1",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3"
  }
}
