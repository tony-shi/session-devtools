{
  "name": "session-dashboard",
  "version": "0.1.0",
  "description": "Local dashboard for visualizing Claude Code, Codex CLI, and Gemini CLI sessions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tony-shi/session-dashboard"
  },
  "workspaces": ["packages/*", "client"],
  "scripts": {
    "dev": "bash scripts/setup-env.sh && bun install --frozen-lockfile && concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "client:dev": "cd client && bun install --frozen-lockfile && bun run dev",
    "build": "cd client && bun run build",
    "start": "bash scripts/setup-env.sh && bun server/index.ts",
    "env:init": "[ -f .env ] || cp .env.example .env && echo 'Created .env from .env.example'",
    "proxy:preflight": "bun run server/src/proxy/cli/preflight.ts",
    "proxy:build": "bun build server/src/proxy/cli/start.ts --target=node --format=esm --outfile=server/src/proxy/dist/start.mjs",
    "proxy:start": "bun run proxy:build && node server/src/proxy/dist/start.mjs",
    "proxy:install": "bun run proxy:build && bun run server/src/proxy/cli/install.ts",
    "proxy:uninstall": "bun run server/src/proxy/cli/uninstall.ts",
    "proxy:status": "bun run server/src/proxy/cli/status.ts",
    "proxy:whitelist": "bun run server/src/proxy/cli/whitelist.ts",
    "proxy:doctor": "bun run server/src/proxy/cli/doctor.ts",
    "proxy:export-share": "bun run server/src/proxy/cli/export-share.ts",
    "context:audit": "bun run scripts/context-audit.ts",
    "context:audit:since-last": "bun run scripts/context-audit.ts --since-last",
    "context:audit:fixtures": "bun run scripts/context-audit.ts --fixtures",
    "context:audit:mark-baseline": "bun run scripts/context-audit.ts mark-baseline",
    "context:audit:clear": "bun run scripts/context-audit.ts clear",
    "context:audit:clear:keep": "bun run scripts/context-audit.ts clear --keep"
  },
  "dependencies": {
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.11",
    "bun-types": "^1.3.12",
    "concurrently": "^9.1.2"
  }
}
